{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "_typecheck": {
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "tsconfig.json"],
      "outputs": [".tsbuildinfo"]
    },
    "_lint": {
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "eslint.config.ts"],
      "outputs": [".eslintcache"]
    },
    "_lint:fix": {
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "eslint.config.ts"],
      "outputs": [".eslintcache"],
      "cache": false
    },
    "_test": {
      "dependsOn": ["_typecheck"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "_check": {
      "dependsOn": ["_typecheck", "_lint"]
    },
    "_validate": {
      "dependsOn": ["_check", "_test"]
    }
  }
}
